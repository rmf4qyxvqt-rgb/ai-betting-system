# Copie para .env e preencha sua chave da API-Sports
API_SPORTS_KEY=SUA_CHAVE_AQUI

# Opcional: chave da Football-Data (app de futebol) para reforcar jogos do dia
FOOTBALL_DATA_KEY=SUA_CHAVE_AQUI

# Opcional: habilita fontes pagas (default false para modo gratis)
USE_PAID_SOURCES=false

# Janela de busca em dias (hoje + proximos N-1 dias)
LOOKAHEAD_DAYS=7

# TTL do cache das fontes (minutos)
SOURCE_CACHE_TTL_MINUTES=30
